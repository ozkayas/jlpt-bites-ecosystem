        "fr": "école"
      },
      "audioUrl": null,
      "sentences": [
        {
          "ja": "毎日、学校へ行きます。",
          "furigana": "<ruby>毎日<rt>まいにち</rt></ruby>、<ruby>学校<rt>がっこう</rt></ruby>へ<ruby>行<rt>い</rt></ruby>きます。",
