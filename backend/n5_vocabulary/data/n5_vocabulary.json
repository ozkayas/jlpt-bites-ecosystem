            "en": "I go to school every day.",
            "tr": "Her gün okula gidiyorum.",
            "de": "Ich gehe jeden Tag zur Schule.",
            "es": "Voy a la escuela todos los días.",
            "fr": "Je vais à l'école tous les jours."
          }
        },
        {
          "ja": "学校は九時に始まります。",
          "furigana": "<ruby>学校<rt>がっこう</rt></ruby>は<ruby>九時<rt>くじ</rt></ruby>に<ruby>始<rt>はじ</rt></ruby>まります。",
          "romaji": "Gakkou wa kuji ni hajimarimasu.",
          "audioUrl": null,
          "translations": {
            "en": "School starts at nine o'clock.",
            "tr": "Okul saat dokuzda başlar.",
            "de": "Die Schule beginnt um neun Uhr.",
            "es": "La escuela empieza a las nueve.",
            "fr": "L'école commence à neuf heures."
          }
        },
        {
          "ja": "私の学校は大きいです。",
          "furigana": "<ruby>私<rt>わたし</rt></ruby>の<ruby>学校<rt>がっこう</rt></ruby>は<ruby>大<rt>おお</rt></ruby>きいです。",
          "romaji": "Watashi no gakkou wa ookii desu.",
          "audioUrl": null,
          "translations": {
            "en": "My school is big.",
            "tr": "Benim okulom büyük.",
            "de": "Meine Schule ist groß.",
            "es": "Mi escuela es grande.",
            "fr": "Mon école est grande."
          }
        }
      ]
    },
