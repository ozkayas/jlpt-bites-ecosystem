{
    "tts_script": [
        {
            "voice": "Intro_Voice",
            "text": "おんなのひとと　おとこのひとが　はなしています。ふたりは　いつ　かいものに　いきますか。"
        },
        {
            "break": "1s"
        },
        {
            "voice": "Female_1",
            "text": "こんしゅうの　どようび　いっしょに　かいものに　いきませんか。"
        },
        {
            "break": "0.5s"
        },
        {
            "voice": "Male_1",
            "text": "すみません、どようびは　あるばいとが　あります。"
        },
        {
            "break": "0.5s"
        },
        {
            "voice": "Female_1",
            "text": "にちようびは　どうですか。"
        },
        {
            "break": "0.5s"
        },
        {
            "voice": "Male_1",
            "text": "にちようびは　ごぜんは　あるばいとですが　ごご　さんじに　おわります。"
        },
        {
            "break": "0.5s"
        },
        {
            "voice": "Female_1",
            "text": "じゃあ　にちようびの　ごご　いきましょう。"
        },
        {
            "break": "0.5s"
        },
        {
            "voice": "Male_1",
            "text": "はい、そうしましょう。"
        },
        {
            "break": "1s"
        },
        {
            "voice": "Intro_Voice",
            "text": "ふたりは　いつ　かいものに　いきますか。"
        }
    ]
}