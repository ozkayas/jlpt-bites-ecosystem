    "transcriptions": {
        "ja": {
            "intro": "パンやで みせのひとと おとこのひとが はなしています。 みせのひとは パンを どうしますか。",
            "dialogue": [
                {
                    "speaker": "女の人",
                    "text": "いらっしゃいませ。"
                },
                {
                    "speaker": "男の人",
                    "text": "すみません。この パンを みっつ ください。"
                },
                {
                    "speaker": "女の人",
                    "text": "はい。これですね。"
                },
                {
                    "speaker": "男の人",
                    "text": "あ、すみません。もう ひとつ おねがいします。"
                },
                {
                    "speaker": "女の人",
                    "text": "はい。ふくろは いりますか。"
                },
                {
                    "speaker": "男の人",
                    "text": "いいえ、いりません。"
                },
                {
                    "speaker": "女の人",
                    "text": "わかりました。"
                }
            ],
            "question": "みせのひとは パンを どうしますか。"
        },
        "tr": {
            "intro": "Fırında görevli ve bir erkek konuşuyor. Görevli ekmekleri ne yapacak?",
            "dialogue": [
                {
                    "speaker": "Kadın",
                    "text": "Hoş geldiniz."
                },
                {
                    "speaker": "Erkek",
                    "text": "Affedersiniz. Bu ekmekten üç tane verin lütfen."
                },
                {
                    "speaker": "Kadın",
                    "text": "Pekala. Bunlar değil mi?"
                },
                {
                    "speaker": "Erkek",
                    "text": "A, özür dilerim. Bir tane daha rica ediyorum."
                },
                {
                    "speaker": "Kadın",
                    "text": "Tamam. Poşet lazım mı?"
                },
                {
                    "speaker": "Erkek",
                    "text": "Hayır, lazım değil."
                },
                {
                    "speaker": "Kadın",
                    "text": "Anladım."
                }
            ],
            "question": "Görevli ekmekleri ne yapacak?"
        },
        "en": {
            "intro": "A shop assistant and a man are talking at a bakery. What will the assistant do with the bread?",
            "dialogue": [
                {
                    "speaker": "Woman",
                    "text": "Welcome."
                },
                {
                    "speaker": "Man",
                    "text": "Excuse me. Please give me three of these buns."
                },
                {
                    "speaker": "Woman",
                    "text": "Certainly. These ones, right?"
                },
                {
                    "speaker": "Man",
                    "text": "Oh, sorry. One more, please."
                },
                {
                    "speaker": "Woman",
                    "text": "Okay. Do you need a bag?"
                },
                {
                    "speaker": "Man",
                    "text": "No, I don't need one."
                },
                {
                    "speaker": "Woman",
                    "text": "Understood."
                }
            ],
            "question": "What will the assistant do with the bread?"
        },
        "de": {
            "intro": "Eine Verkäuferin und ein Mann sprechen in einer Bäckerei. Was wird die Verkäuferin mit dem Brot machen?",
            "dialogue": [
                {
                    "speaker": "Frau",
                    "text": "Willkommen."
                },
                {
                    "speaker": "Mann",
                    "text": "Entschuldigung. Bitte geben Sie mir drei von diesen Brötchen."
                },
                {
                    "speaker": "Frau",
                    "text": "Gerne. Diese hier, richtig?"
                },
                {
                    "speaker": "Mann",
                    "text": "Oh, Verzeihung. Bitte noch eins dazu."
                },
                {
                    "speaker": "Frau",
                    "text": "In Ordnung. Benötigen Sie eine Tüte?"
                },
                {
                    "speaker": "Mann",
                    "text": "Nein, danke."
                },
                {
                    "speaker": "Frau",
                    "text": "Verstanden."
                }
            ],
            "question": "Was wird die Verkäuferin mit dem Brot machen?"
        },
        "fr": {
            "intro": "Une vendeuse et un homme parlent dans une boulangerie. Que va faire la vendeuse avec le pain ?",
            "dialogue": [
                {
                    "speaker": "Femme",
                    "text": "Bienvenue."
                },
                {
                    "speaker": "Homme",
                    "text": "Excusez-moi. Donnez-m'en trois comme ça s'il vous plaît."
                },
                {
                    "speaker": "Femme",
                    "text": "D'accord. Ceux-là ?"
                },
                {
                    "speaker": "Homme",
                    "text": "Ah, pardon. Un autre en plus s'il vous plaît."
                },
                {
                    "speaker": "Femme",
                    "text": "D'accord. Voulez-vous un sac ?"
                },
                {
                    "speaker": "Homme",
                    "text": "Non, ce n'est pas la peine."
                },
                {
                    "speaker": "Femme",
                    "text": "Entendu."
                }
